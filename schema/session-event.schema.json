{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Session Event",
    "description": "Append-only normalized event record for a persistent interactive session",
    "type": "object",
    "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "sessionId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
    },
    "required": ["id", "type", "sessionId", "timestamp"],
    "additionalProperties": true
}
