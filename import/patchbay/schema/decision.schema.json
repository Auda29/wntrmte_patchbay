{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Decision",
    "description": "A technical decision logged in the architecture",
    "type": "object",
    "properties": {
        "id": {
            "type": "string",
            "description": "Unique identifier for the decision (e.g., 'DEC-001')"
        },
        "title": {
            "type": "string",
            "description": "Short title of the decision"
        },
        "rationale": {
            "type": "string",
            "description": "The reasoning behind the decision"
        },
        "proposedBy": {
            "type": "string",
            "description": "Who proposed the decision"
        },
        "approvedBy": {
            "type": "string",
            "description": "Who approved the decision"
        },
        "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "When the decision was made"
        }
    },
    "required": [
        "id",
        "title",
        "rationale",
        "timestamp"
    ],
    "additionalProperties": false
}